---
import Layout from '../layouts/main.astro';
import TopNav from '../components/TopNav.astro';
import GalleryView from '../components/Photobooth/GalleryView.tsx';
---

<Layout title="Virtual Photobooth - Gallery" bodyClass="bg-surface-container-low min-h-screen flex flex-col font-body-md text-on-background antialiased selection:bg-primary-container selection:text-on-primary-container relative overflow-x-hidden">
    <TopNav />
    
    <main class="flex-1 flex flex-col items-center pt-24 pb-12 px-6 w-full max-w-container-max mx-auto relative z-10">
        <GalleryView client:load />
    </main>
</Layout>
