            <div class="absolute inset-0 bg-black/40 z-10 opacity-0 group-hover:opacity-20 transition-opacity"></div>
            <div class="selection-indicator hidden absolute top-3 right-3 z-20 bg-primary text-on-primary rounded-full p-1 shadow-md">
                <span class="material-symbols-outlined icon-fill text-sm" data-icon="check_circle">check_circle</span>
            </div>
            <div class="w-full aspect-[1/3] relative">
                <img src="/frames/frame-pink.png" alt="Pink Frame" class="w-full h-full object-contain" />
            </div>
            <div class="absolute bottom-0 left-0 w-full p-3 z-20 bg-gradient-to-t from-black/80 to-transparent">
                <h3 class="font-h3 text-base text-white drop-shadow-md">Pink Circle</h3>
