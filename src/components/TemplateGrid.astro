</main>

<div class="fixed bottom-24 md:bottom-8 left-0 w-full px-6 flex justify-center z-40 pointer-events-none">
    <Button id="btn-selanjutnya" className="pointer-events-auto flex items-center gap-2 bg-primary hover:bg-primary-container text-on-primary font-label-sm text-label-sm px-8 py-6 rounded-full shadow-lg shadow-primary/30 transform hover:scale-105 transition-all duration-300 border-none opacity-50 cursor-not-allowed">
        <span>Selanjutnya</span>
        <span class="material-symbols-outlined text-lg" data-icon="arrow_forward">arrow_forward</span>
    </Button>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cards = document.querySelectorAll('.template-card');
        const btnSelanjutnya = document.getElementById('btn-selanjutnya');
        let selectedTemplate = null;
        let selectedPhotoCount = null;

        const resetSelection = () => {
            cards.forEach(card => {
                card.classList.remove('ring-4', 'ring-primary', 'scale-[1.02]');
                card.classList.add('shadow-sm', 'hover:-translate-y-1', 'hover:ring-2', 'hover:ring-primary-fixed');
                card.querySelector('.selection-indicator').classList.add('hidden');
            });
        };

        cards.forEach(card => {
            card.addEventListener('click', () => {
                resetSelection();
                
                selectedTemplate = card.dataset.templateId;
                selectedPhotoCount = card.dataset.photoCount;
                
                card.classList.remove('shadow-sm', 'hover:-translate-y-1', 'hover:ring-2', 'hover:ring-primary-fixed');
                card.classList.add('ring-4', 'ring-primary', 'scale-[1.02]');
                card.querySelector('.selection-indicator').classList.remove('hidden');

                btnSelanjutnya.classList.remove('opacity-50', 'cursor-not-allowed');
            });
        });

        btnSelanjutnya.addEventListener('click', (e) => {
            if (!selectedTemplate) {
                e.preventDefault();
                alert('Pilih frame terlebih dahulu!');
                return;
            }
            sessionStorage.setItem('photobooth-template', selectedTemplate);
            sessionStorage.setItem('photobooth-photo-count', selectedPhotoCount);
            window.location.href = '/capture';
        });
    });
</script>
