---
import { Button } from "@/components/ui/button"
---

<main class="flex-grow flex flex-col items-center px-4 md:px-gutter max-w-container-max mx-auto w-full mt-8">
    <div class="text-center mb-10 w-full max-w-2xl">
        <h1 class="font-h1 text-h1 text-on-surface mb-4">Pilih Frame Favoritmu</h1>
