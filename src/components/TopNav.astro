---
import { Button } from "@/components/ui/button"
const pathname = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border-b border-white/20 dark:border-slate-800/50 shadow-sm shadow-primary/5">
    <div class="flex items-center gap-4">
        <span class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary to-[#780000] font-['Spline_Sans'] tracking-tight">A-Snap</span>
    </div>
    <div class="hidden md:flex items-center gap-4">
        <!-- Top Nav items -->
        <nav class="flex gap-6">
            <a class={`font-['Spline_Sans'] tracking-tight hover:bg-slate-100/50 dark:hover:bg-slate-800/50 transition-all duration-200 px-3 py-2 rounded-md ${pathname === '/' ? 'text-primary font-bold border-b-2 border-primary' : 'text-slate-500 dark:text-slate-400 font-medium'}`} href="/">Home</a>
            <a class={`font-['Spline_Sans'] tracking-tight hover:bg-slate-100/50 dark:hover:bg-slate-800/50 transition-all duration-200 px-3 py-2 rounded-md ${pathname.startsWith('/session') || pathname.startsWith('/capture') || pathname.startsWith('/result') ? 'text-primary font-bold border-b-2 border-primary' : 'text-slate-500 dark:text-slate-400 font-medium'}`} href="/session">Session</a>
            <a class={`font-['Spline_Sans'] tracking-tight hover:bg-slate-100/50 dark:hover:bg-slate-800/50 transition-all duration-200 px-3 py-2 rounded-md ${pathname.startsWith('/gallery') ? 'text-primary font-bold border-b-2 border-primary' : 'text-slate-500 dark:text-slate-400 font-medium'}`} href="/gallery">Gallery</a>
        </nav>
    </div>
    <div class="flex items-center gap-2 text-primary">
        <Button variant="ghost" size="icon" className="hover:bg-slate-100/50 dark:hover:bg-slate-800/50 transition-all duration-200 rounded-full text-primary">
            <span class="material-symbols-outlined text-[24px]" data-icon="help">help</span>
        </Button>
        <Button variant="ghost" size="icon" className="hover:bg-slate-100/50 dark:hover:bg-slate-800/50 transition-all duration-200 rounded-full text-primary">
            <span class="material-symbols-outlined text-[24px]" data-icon="settings">settings</span>
        </Button>
    </div>
</header>
