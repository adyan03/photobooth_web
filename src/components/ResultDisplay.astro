<div class="flex flex-col items-center justify-center mb-10 text-center">
    <div class="w-16 h-16 rounded-full bg-primary-container flex items-center justify-center mb-4 shadow-[0_0_30px_rgba(124,58,237,0.2)]">
        <span class="material-symbols-outlined text-[32px] text-primary" style="font-variation-settings: 'FILL' 1;">task_alt</span>
    </div>
    <h1 class="font-h2 text-h2 text-on-surface mb-2">Fotomu sudah siap!</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-md">Sesi photobooth Anda telah berhasil diproses dan siap untuk disimpan.</p>
</div>

<div class="relative group perspective-[1000px] mb-12">
    <!-- Ambient shadow behind the strip -->
    <div class="absolute inset-0 bg-primary/20 blur-[40px] transform scale-105 rounded-xl z-0 transition-opacity duration-300 opacity-70 group-hover:opacity-100"></div>
    
    <!-- The Physical Strip -->
    <div class="relative z-10 bg-surface-container-lowest p-4 pb-8 w-[280px] sm:w-[320px] rounded-sm shadow-[0_25px_50px_-12px_rgba(99,14,212,0.25)] border border-outline-variant/40 transform rotate-[-2deg] hover:rotate-0 hover:scale-[1.02] transition-all duration-500 ease-out flex flex-col gap-4">
        <!-- Photo 1 -->
        <div class="w-full aspect-[4/3] bg-surface-container rounded-sm overflow-hidden relative border border-outline-variant/20">
            <img alt="Group photo one" class="w-full h-full object-cover filter contrast-105 saturate-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCUb_gRl3ijHVX6dysw2Z6g3cgrPa1tGt1pWjYnDJXJPcV8wE5jjw3LcdqWU6gA4VBwijeB9SuuR1nxlnhvde-apxFna7w1r3nWTYc9j2Ed0zsZl-PXcGMTFrT3TrZTPN7XeQHuhuqkcC1_WY2uv3iLB72KOzE53Ls8vQ8oEvFbH57JpOiYjND0YYouRTjFnSeIIgVy3Gs3JkZTrdQFRAaxrl1Ru6CPA6SGK4mRDj7DP7gY2dN5DLSZJnjJJ8cGzzjFZ5if2w9FV_ib"/>
        </div>
        <!-- Photo 2 -->
        <div class="w-full aspect-[4/3] bg-surface-container rounded-sm overflow-hidden relative border border-outline-variant/20">
            <img alt="Group photo two" class="w-full h-full object-cover filter contrast-105 saturate-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAs9BFCwUPytLtJswqK_LUcEb4lzXS75EV9_t9hQb8-qnlK8xo7hQbbvqkE901Nd87vf94TA2VJji-_NcZ6_0uGrepUYGmNWs_5EPRJCHhiKdSWxFgkaNQTKBNOKVMpERQVphdO2r9rMSNynpZ3wUWPIF0u1ZkQVO6z9Mu4JljIu6nHevL2MkcGvbpWkckAlrBbzHvTo_jaWHUBYIW2CfxlzlwqcwDQ27QAmRzXPoKq6K5Fxcg8dT7VHwkEubdktmgJwuqNFHl44h9x"/>
        </div>
        <!-- Photo 3 -->
        <div class="w-full aspect-[4/3] bg-surface-container rounded-sm overflow-hidden relative border border-outline-variant/20">
            <img alt="Group photo three" class="w-full h-full object-cover filter contrast-105 saturate-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAh6S6majlil52RurrD4xh2w3OaIkU_xxAiAXu4EbbuEzGkBzWvNlEBDnjptHo5wDqGtZ7kWtLkFA7dEQd7iq77KaJDwyv6n9Q_lLJsqi0df7g4w8WBA9uv8C17xeYw5i9ZBLWHg_37tGxMqp_WUmupyc1IGntQe1GoNGAIWcG-oDA-Tbd-Wr8MzlN2-XbWs2GJDN9Q6As2fWyiZf2uSWRVaPnJj9WiwE6EH11c1voP1IL5Uqcwko8q_ZvgKlpom-uquW3tOXdMuATM"/>
        </div>
        <!-- Strip Footer / Template Branding -->
        <div class="pt-4 mt-2 border-t border-outline-variant/30 flex flex-col items-center justify-center">
            <span class="font-h3 text-h3 text-primary tracking-tight leading-none mb-1">VIRTUAL</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-[0.2em] text-[10px]">Photobooth 2024</span>
        </div>
        <!-- Subtle reflection overlay for glass/glossy photo paper effect -->
        <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-white/20 pointer-events-none rounded-sm"></div>
    </div>
</div>
