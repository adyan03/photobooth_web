---
import { Button } from "@/components/ui/button"
---

<main class="w-full max-w-container-max px-gutter md:px-lg flex flex-col items-center text-center z-10">
    <div class="relative w-40 h-40 mx-auto mb-10 animate-float">
        <div class="absolute inset-0 bg-primary/30 blur-2xl rounded-full scale-110"></div>
        <div class="relative w-full h-full bg-surface border-4 border-surface-container-highest rounded-full overflow-hidden flex items-center justify-center shadow-[0_20px_50px_rgba(0,0,0,0.5)] transform hover:scale-105 transition-all duration-500 ring-2 ring-primary/20">
            <img src="/camera-logo.jpg" alt="Leica Camera Lens Logo" class="w-full h-full object-cover" />
        </div>
    </div>
    <div class="max-w-2xl mx-auto space-y-sm mb-xl">
        <h1 class="font-h1 text-h1 text-on-surface tracking-tight bg-clip-text text-transparent bg-gradient-to-br from-on-surface to-primary leading-tight">
            Capture the Moment. <br class="hidden md:block"/> Cherish the Memory.
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
            Siap mengabadikan momen terbaikmu hari ini bersama A-Snap?
        </p>
    </div>
    <Button asChild className="bg-primary text-on-primary font-label-sm text-label-sm px-12 py-6 btn-pulse flex items-center gap-2 btn-3d-glossy">
        <a href="/session">
            Mulai
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </a>
    </Button>
</main>
