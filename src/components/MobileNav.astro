---
const currentPath = Astro.url.pathname;

const navItems = [
  { path: '/', icon: 'home', label: 'Home' },
  { path: '/session', icon: 'camera', label: 'Session', matches: ['/session', '/capture', '/result'] },
  { path: '/gallery', icon: 'photo_library', label: 'Gallery' }
];

const isMatch = (itemPath: string, matches?: string[]) => {
    if (matches && matches.includes(currentPath)) return true;
    if (currentPath === '/' && itemPath === '/') return true;
    if (itemPath !== '/' && currentPath.startsWith(itemPath)) return true;
    return false;
};
---

<div class="md:hidden fixed bottom-0 left-0 w-full bg-surface-container-highest/90 backdrop-blur-xl border-t border-white/10 z-[100] px-6 py-2 flex justify-around items-center shadow-[0_-10px_40px_rgba(0,0,0,0.1)] pb-[env(safe-area-inset-bottom)]">
    {navItems.map(item => {
        const active = isMatch(item.path, item.matches);
        return (
            <a href={item.path} class={`flex flex-col items-center gap-1 p-2 transition-colors ${active ? 'text-primary' : 'text-on-surface-variant hover:text-on-surface'}`}>
                <span class={`material-symbols-outlined text-[28px] ${active ? 'icon-fill' : ''}`}>{item.icon}</span>
                <span class="text-[10px] font-medium leading-none">{item.label}</span>
            </a>
        );
    })}
</div>
